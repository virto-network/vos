# Per-target rustflags so the same source compiles for all three
# build flavors. `-Zcrate-attr` injects crate-level attributes the
# user shouldn't have to write.

[target.riscv64em-javm]
rustflags = [
    "-Zunstable-options",
    "-Zcrate-attr=no_std",
    "-Zcrate-attr=no_main",
    "-Aduplicate-macro-attributes",
    "-Aunused-attributes",
]

[target.wasm32-unknown-unknown]
rustflags = [
    "-Zunstable-options",
    "-Zcrate-attr=no_std",
    # crate-attr applies to every rustc invocation in this build
    # session, including vos itself (which already has its own
    # `#![cfg_attr(not(feature = "std"), no_std)]`). The duplicate
    # is harmless; silence the lint so build output stays clean.
    "-Aunused-attributes",
]

# Aliases drive target + feature selection per flavor. Each alias
# explicitly sets `--target` so they don't conflict with each
# other. `build-std` lives on the actor alias only — the custom
# JSON target needs core/alloc rebuilt from source; host and
# wasm use the prebuilt sysroot.
#
# Run `cargo actor` for the PVM ELF (the most common case for
# this crate).  `cargo worker` builds the host plugin .so;
# `cargo wasm` builds the wasm32 module.  Plain `cargo build`
# defaults to the host target — fails fast for actors that use
# PVM-only APIs (`ctx.yield_now`, etc.).
[alias]
actor = "build -Zbuild-std=core,alloc,compiler_builtins -Zbuild-std-features=compiler-builtins-mem --release --target riscv64em-javm.json"
worker = "build --release --no-default-features"
wasm = "build --release --no-default-features --target wasm32-unknown-unknown"

[unstable]
json-target-spec = true
