[workspace]

[package]
name = "counter"
version = "0.1.0"
edition = "2024"

[features]
# `bin` enables PVM entry-point emission (`_start`, `accumulate`,
# `.vos_meta`). Default-on so a plain `cargo build` (or
# `cargo actor`) produces an actor ELF; consumers depending on
# this crate as a Ref source turn it off via
# `default-features = false` so no entries land in their link.
default = ["bin"]
bin = []

[lib]
# rlib  : usable as Ref source by other actors / host crates.
# cdylib: produces the worker `.so` on host targets and the wasm
#         `.wasm` on wasm32 targets. The same `#[messages]`-emitted
#         glue lives behind both depending on the active vos feature.
crate-type = ["rlib", "cdylib"]

[[bin]]
name = "counter"
path = "src/lib.rs"
required-features = ["bin"]

# Target-conditional vos deps — pick the right feature set per
# build target so each artifact gets only the glue it needs:
#   - riscv64em-javm → service (PVM JAM lifecycle)
#   - wasm32         → wasm-bootstrap (cdylib + dlmalloc + panic stub)
#   - host (default) → worker (native cdylib plugin glue)

[target.'cfg(target_arch = "riscv64")'.dependencies]
vos = { path = "{{vos_path}}", default-features = false, features = ["macros", "service"] }

[target.'cfg(target_arch = "wasm32")'.dependencies]
vos = { path = "{{vos_path}}", default-features = false, features = ["macros", "wasm-bootstrap"] }

[target.'cfg(not(any(target_arch = "riscv64", target_arch = "wasm32")))'.dependencies]
vos = { path = "{{vos_path}}", default-features = false, features = ["macros", "worker"] }

[profile.release]
opt-level = "s"
lto = true
panic = "abort"
