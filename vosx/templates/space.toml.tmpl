space = "{{name}}"
version = "0.1.0"

# A starter space with one Raft-backed actor. Run with:
#   vosx up
#
# To form a multi-node cluster, run on multiple machines:
#   # bootstrap node:
#   vosx up --listen /ip4/0.0.0.0/tcp/4811
#
#   # joiners (each):
#   vosx join /ip4/<bootnode-ip>/tcp/4811/p2p/<peer-id>

[[agent]]
name = "counter"
path = "actors/counter/target/riscv64em-javm/release/counter.elf"
consistency = "raft"
# `replication_id` defaults to "auto" =
# `blake2b(name || 0 || blob)`. Every replica that names this
# agent "counter" with the same compiled binary auto-shares a
# Raft group.
